# .env.example
# Sample environment variables for Coinstack application.
# Copy this file to .env and fill in your actual values.

# Plaid API credentials
# Get these from your Plaid dashboard (https://dashboard.plaid.com/team/keys)
PLAID_CLIENT_ID="your_plaid_client_id_here"
PLAID_SECRET="your_plaid_secret_here"
PLAID_ENV="sandbox" # Use 'sandbox', 'development', or 'production'

# Placeholder for database connection string
# DATABASE_URL="sqlite:///./coinstack.db"

# Debug mode (true/false) - can be overridden by CLI args
# COINSTACK_DEBUG="false"
