# .env.example
# Sample environment variables for Coinstack application.
# Copy this file to .env and fill in your actual values.

# Placeholder for bank API key (e.g., Plaid, Finicity)
# BANK_API_KEY="your_bank_api_key_here"

# Placeholder for database connection string
# DATABASE_URL="sqlite:///./coinstack.db"

# Debug mode (true/false) - can be overridden by CLI args
COINSTACK_DEBUG=False